# =============================================================================
# fsdeploy .gitignore
# =============================================================================

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
*.whl

# ── Environments ──────────────────────────────────────────────────────────────
.env
.venv/
venv/
ENV/

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ── Tests / coverage ─────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.mypy_cache/
.dmypy.json

# ── fsdeploy runtime ─────────────────────────────────────────────────────────
var/lib/fsdeploy/*
var/log/fsdeploy/*
logs/
*.log

# ── OS ────────────────────────────────────────────────────────────────────────
Thumbs.db
var/lib/fsdeploy/*
var/log/fsdeploy/*
*.pyc
__pycache__/
.cache/
.aider*
sys
